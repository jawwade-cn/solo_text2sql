# 数据库连接配置
DB_TYPE=sqlite  # 可选: sqlite, mysql, postgresql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=test
DB_PATH=./example.db  # 仅SQLite使用

# LLM配置 (用于自然语言转SQL)
LLM_TYPE=openai  # 可选: openai, local
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
# 本地模型配置
LOCAL_MODEL_PATH=./models/local_model
