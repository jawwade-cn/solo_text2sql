# 数据库连接配置
DB_TYPE=sqlite  # 可选: sqlite, mysql, postgresql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=test
DB_PATH=./example.db  # 仅SQLite使用

# LLM配置 (用于自然语言转SQL)
# 注意：现在可以通过GUI界面的"设置"按钮配置多种LLM平台
# 以下配置仅作为参考，GUI配置会覆盖这些设置

# OpenAI 平台配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Nvidia NIM 平台配置
# 用于调用 qwen3.5-397b-a17b, qwen2.5-72b-instruct 等模型
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
NVIDIA_NIM_MODEL=qwen3.5-397b-a17b
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# 阿里云 Qwen 平台配置 (通义千问)
QWEN_API_KEY=your_qwen_api_key
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek 平台配置
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 自定义 OpenAI 兼容平台配置
CUSTOM_API_KEY=your_custom_api_key
CUSTOM_MODEL=custom-model-name
CUSTOM_BASE_URL=http://localhost:8000/v1

# LLM通用参数
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
